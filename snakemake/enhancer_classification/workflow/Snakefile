configfile: "config/config.yaml"


include: "rules/common.smk"
include: "rules/data.smk"
include: "rules/model.smk"
include: "rules/segmentation.smk"
include: "rules/visualization.smk"


MODEL_NAMES = [k for k in config.get("models", {}) if k != "default"]
EXPERIMENTS = config.get("experiments", [])
SEG_MODEL_NAMES = [k for k in config.get("seg_models", {}) if k != "default"]
SEG_DATASET_NAMES = list(config.get("seg_datasets", {}).keys())
SEG_EXPERIMENTS = config.get("seg_experiments", [])


ruleorder: filter_no_exon_overlap > process_cre
ruleorder: cre_filter_conserved > filter_cre_class
ruleorder: filter_no_exon_overlap > filter_cre_class
ruleorder: filter_no_exon_overlap > cre_filter_conserved
# Needed after generalizing to the `{cre_class}` wildcard: without this,
# `process_cre` (output: {species}/all.parquet) matches whenever the species
# wildcard is under-constrained, including bogus paths like
# `{species}/{cre_class}_conservation/{conservation}.parquet`.
ruleorder: cre_conservation > process_cre
ruleorder: cre_conservation > filter_cre_class
ruleorder: process_cre > filter_cre_class
ruleorder: build_segmentation_fullcov_validation > build_segmentation_dataset


_ALL_DATASETS = list(set(DATASET_NAMES) | set(SEG_DATASET_NAMES))
_ALL_MODELS = list(set(MODEL_NAMES) | set(SEG_MODEL_NAMES))


wildcard_constraints:
    species="|".join(SPECIES),
    dataset="|".join(_ALL_DATASETS),
    intervals="|".join(ALL_INTERVALS),
    split_name="|".join(ALL_SPLIT_NAMES),
    conservation="|".join(ALL_CONSERVATIONS),
    label_type="positives|negatives|negative_candidates|negatives_gc_repeat_matched",
    neg_type="|".join(ALL_NEG_TYPES),
    n=r"\d+",
    model="|".join(_ALL_MODELS) if _ALL_MODELS else "NONE",
    window_size=r"\d+",
    windows_kind="labeled_windows|sampled_windows",


rule all:
    input:
        get_all_dataset_outputs(),
        [
            f"results/model/{exp['model']}/{exp['dataset']}/metrics.json"
            for exp in EXPERIMENTS
        ],
        [
            f"results/model/{exp['model']}/{exp['dataset']}/misclassified.parquet"
            for exp in EXPERIMENTS
        ],
        [
            f"results/model/{exp['model']}/{exp['dataset']}/precision_recall.parquet"
            for exp in EXPERIMENTS
        ],
        [
            f"results/visualization/{ckpt['model']}/{ckpt['dataset']}/{region['name']}.bedgraph"
            for ckpt in config.get("visualization", {}).get("checkpoints", [])
            for region in config.get("visualization", {}).get("regions", [])
        ],


rule all_segmentation:
    input:
        [
            f"results/segmentation/model/{exp['model']}/{exp['dataset']}/metrics.json"
            for exp in SEG_EXPERIMENTS
        ],
        [
            f"results/segmentation/model/{exp['model']}/{exp['dataset']}/precision_recall.parquet"
            for exp in SEG_EXPERIMENTS
        ],
        [
            f"results/segmentation/visualization/{ckpt['model']}/{ckpt['dataset']}/{region['name']}.bedgraph"
            for ckpt in config.get("segmentation_visualization", {}).get(
                "checkpoints", []
            )
            for region in config.get("segmentation_visualization", {}).get(
                "regions", []
            )
        ],


# Positive-set-definition exploration (sub-issue of #96). Isolates the five
# new experiments from `all_segmentation` so we don't trigger retraining of
# the original `seg_v1` experiments (whose intermediate `sampled_windows`
# parquets aren't in S3, causing a spurious DAG cascade).
SEG_POS_EXPLORATION_DATASETS = [
    "seg_v1_64k",
    "seg_pos_all_64k",
    "seg_pos_cons30_64k",
    "seg_pos_cons50_64k",
    "seg_pos_withexon_64k",
]
SEG_POS_EXPLORATION_MODEL = "xfmr2_w64k_s42"


rule all_seg_pos_exploration:
    input:
        [
            f"results/segmentation/model/{SEG_POS_EXPLORATION_MODEL}/{d}/metrics.json"
            for d in SEG_POS_EXPLORATION_DATASETS
        ],
        [
            f"results/segmentation/model/{SEG_POS_EXPLORATION_MODEL}/{d}/precision_recall.parquet"
            for d in SEG_POS_EXPLORATION_DATASETS
        ],
        [
            f"results/segmentation/model/{SEG_POS_EXPLORATION_MODEL}/{d}/misclassified.parquet"
            for d in SEG_POS_EXPLORATION_DATASETS
        ],
        [
            f"results/segmentation/visualization/{SEG_POS_EXPLORATION_MODEL}/{d}/{region['name']}.bedgraph"
            for d in SEG_POS_EXPLORATION_DATASETS
            for region in config.get("segmentation_visualization", {}).get(
                "regions", []
            )
        ],
